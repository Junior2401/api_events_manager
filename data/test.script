CREATE USER SA PASSWORD DIGEST 'd41d8cd98f00b204e9800998ecf8427e'
ALTER USER SA SET LOCAL TRUE
CREATE SCHEMA PUBLIC AUTHORIZATION DBA
CREATE MEMORY TABLE PUBLIC.EVENEMENT(CAPACITE INTEGER,DATE TIMESTAMP,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,TYPE_EVENEMENT_ID BIGINT,DESCRIPTION VARCHAR(255),LIBELLE VARCHAR(255),LIEU VARCHAR(255),STATUT VARCHAR(255),CHECK((PUBLIC.EVENEMENT.STATUT) IN (('CREE'),('VALIDE'),('ANNULE'),('PLANIFIE'))))
ALTER TABLE PUBLIC.EVENEMENT ALTER COLUMN ID RESTART WITH 5
CREATE MEMORY TABLE PUBLIC.EVENEMENT_TYPES_PLACE(EVENEMENT_ID BIGINT NOT NULL,TYPE_PLACE VARCHAR(255),CONSTRAINT FKBMVL2OPGOOFPIWDU8AIUBG4Y5 FOREIGN KEY(EVENEMENT_ID) REFERENCES PUBLIC.EVENEMENT(ID))
CREATE MEMORY TABLE PUBLIC.ORGANISER(EVENEMENT_ID BIGINT NOT NULL,ORGANISATEUR_ID BIGINT NOT NULL,PRIMARY KEY(EVENEMENT_ID,ORGANISATEUR_ID),CONSTRAINT FKK1DRNKBDYR7O3UDKNR886NDOS FOREIGN KEY(EVENEMENT_ID) REFERENCES PUBLIC.EVENEMENT(ID))
CREATE MEMORY TABLE PUBLIC.PARTICIPER(ARTISTE_ID BIGINT NOT NULL,EVENEMENT_ID BIGINT NOT NULL,PRIMARY KEY(ARTISTE_ID,EVENEMENT_ID),CONSTRAINT FKH8YRX8J9NH3O1S3MLHLN8HP8P FOREIGN KEY(EVENEMENT_ID) REFERENCES PUBLIC.EVENEMENT(ID))
CREATE MEMORY TABLE PUBLIC.PERSONNE(NUMERO INTEGER,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,TYPE_PERSONNE VARCHAR(31) NOT NULL,EMAIL VARCHAR(255),NOM VARCHAR(255),NOMDESCENE VARCHAR(255),PASSWORD VARCHAR(255),PRENOM VARCHAR(255),ROLE VARCHAR(255),RUE VARCHAR(255),SOCIETE VARCHAR(255),STYLEARTISTIQUE VARCHAR(255),TELEPHONE VARCHAR(255),TELEPHONEPRO VARCHAR(255),VILLE VARCHAR(255))
ALTER TABLE PUBLIC.PERSONNE ALTER COLUMN ID RESTART WITH 11
CREATE MEMORY TABLE PUBLIC.TICKET(PRIX INTEGER,DATEACHAT TIMESTAMP NOT NULL,DATEANNULATION TIMESTAMP,DATEREMBOURSEMENT TIMESTAMP,EVENEMENT_ID BIGINT,ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,UTILISATEUR_ID BIGINT,NUMEROPLACE VARCHAR(255) NOT NULL,PLACE VARCHAR(255),STATUT VARCHAR(255) NOT NULL,CHECK((PUBLIC.TICKET.STATUT) IN (('ACHETE'),('ANNULE'),('REMBOURSE'))),CONSTRAINT FKNXP90MOS6EBNX1TOPH4OQO6A FOREIGN KEY(EVENEMENT_ID) REFERENCES PUBLIC.EVENEMENT(ID),CONSTRAINT FK2MP1P8SF22TSVDYJDO4B4WGSU FOREIGN KEY(UTILISATEUR_ID) REFERENCES PUBLIC.PERSONNE(ID))
ALTER TABLE PUBLIC.TICKET ALTER COLUMN ID RESTART WITH 7
CREATE MEMORY TABLE PUBLIC.TYPEEVENEMENT(ID BIGINT GENERATED BY DEFAULT AS IDENTITY(START WITH 1) NOT NULL PRIMARY KEY,DESCRIPTION VARCHAR(255),LIBELLE VARCHAR(255))
ALTER TABLE PUBLIC.TYPEEVENEMENT ALTER COLUMN ID RESTART WITH 4
ALTER TABLE PUBLIC.EVENEMENT ADD CONSTRAINT FKAW6QQ4SUKX3HVRYU2PYNCEVVS FOREIGN KEY(TYPE_EVENEMENT_ID) REFERENCES PUBLIC.TYPEEVENEMENT(ID)
ALTER TABLE PUBLIC.ORGANISER ADD CONSTRAINT FKC0EAS02LJ0GPD3K0GB4W07EA2 FOREIGN KEY(ORGANISATEUR_ID) REFERENCES PUBLIC.PERSONNE(ID)
ALTER TABLE PUBLIC.PARTICIPER ADD CONSTRAINT FK2B4C92C2BBFAGF7QCGULD7W0G FOREIGN KEY(ARTISTE_ID) REFERENCES PUBLIC.PERSONNE(ID)
ALTER SEQUENCE SYSTEM_LOBS.LOB_ID RESTART WITH 1
